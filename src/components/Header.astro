---
const isHome = Astro.url.pathname === '/';
---
<header class="header">
  <a href="/" class="header-logo">
    <div class="logo-mark">H</div>
    <div>
      HyperGrad
      <div class="logo-sub">DevTools · 开发者工具箱</div>
    </div>
  </a>
  <div class="header-search">
    <input type="search" id="site-search" placeholder="搜索工具（如 JSON、正则、加密...）" autocomplete="off" />
  </div>
  <nav class="header-nav">
    <a href="/">全部工具</a>
    <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 官网</a>
    <a href="https://hypergrad.cn#pricing" target="_blank" rel="noopener" class="header-cta">下载 DeepSeal</a>
  </nav>
</header>
<script>
  // 站内搜索：输入关键词跳转匹配工具
  const search = document.getElementById('site-search') as HTMLInputElement | null;
  const tools = JSON.parse('[{"slug":"json-formatter","name":"JSON 格式化","shortName":"JSON","keywords":["json格式化","json在线解析","json校验","json压缩","json美化","json树形"]},{"slug":"encrypt","name":"加密 / 解密","shortName":"加解密","keywords":["加密解密","md5加密","base64编码","aes加密","des加密","sha256","在线解密"]},{"slug":"regex-tester","name":"正则表达式测试","shortName":"正则","keywords":["正则表达式","正则在线测试","正则语法","正则匹配","正则可视化"]},{"slug":"timestamp","name":"时间戳转换","shortName":"时间戳","keywords":["时间戳转换","unix时间戳","毫秒时间戳","时间戳转日期","在线时间戳"]},{"slug":"radix","name":"进制转换","shortName":"进制","keywords":["进制转换","二进制转十进制","十六进制转换","八进制","进制计算器"]},{"slug":"url-encode","name":"URL 编码 / 解码","shortName":"URL","keywords":["url编码","url解码","url encode","url转义","百分号编码"]},{"slug":"base64","name":"Base64 编解码","shortName":"Base64","keywords":["base64","base64编码","base64解码","图片转base64","base64转图片"]},{"slug":"hash","name":"Hash 生成器","shortName":"Hash","keywords":["hash生成","md5","sha1","sha256","sha512","哈希计算"]},{"slug":"qrcode","name":"二维码生成 / 解析","shortName":"二维码","keywords":["二维码","二维码生成","二维码解析","qrcode"]},{"slug":"image-compress","name":"图片压缩","shortName":"图片压缩","keywords":["图片压缩","照片压缩","在线压缩图片","png压缩","jpg压缩"]},{"slug":"pdf-merge","name":"PDF 合并","shortName":"PDF","keywords":["pdf合并","pdf合并在线","pdf合并工具","在线合并pdf"]},{"slug":"sql-formatter","name":"SQL 格式化","shortName":"SQL","keywords":["sql格式化","sql美化","sql压缩","sql在线工具"]},{"slug":"json-to-class","name":"JSON 转实体类","shortName":"JSON转类","keywords":["json转实体类","json转java","json转c#","json转go","json转python"]},{"slug":"js-formatter","name":"JS 格式化 / 压缩","shortName":"JS","keywords":["js格式化","js美化","js压缩","javascript格式化"]},{"slug":"css-formatter","name":"CSS 格式化 / 压缩","shortName":"CSS","keywords":["css格式化","css美化","css压缩","css在线工具"]},{"slug":"html-formatter","name":"HTML 格式化","shortName":"HTML","keywords":["html格式化","html美化","html压缩","html在线工具"]},{"slug":"uuid","name":"UUID 生成","shortName":"UUID","keywords":["uuid","uuid生成","guid生成","在线uuid"]},{"slug":"jwt","name":"JWT 解析","shortName":"JWT","keywords":["jwt","jwt解析","jwt解码","jwt token"]},{"slug":"cron","name":"Cron 表达式解析","shortName":"Cron","keywords":["cron","cron表达式","cron解析","定时任务"]},{"slug":"color","name":"颜色转换","shortName":"颜色","keywords":["颜色转换","hex转rgb","rgb转hex","hsl转换","调色板"]}]');
  if (search) {
    search.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = search.value.trim().toLowerCase();
        if (!q) return;
        // 全字段匹配
        let best = tools.find((t: any) =>
          t.name.toLowerCase().includes(q) ||
          t.shortName.toLowerCase().includes(q) ||
          t.slug.includes(q) ||
          t.keywords.some((k: string) => k.toLowerCase().includes(q) || q.includes(k.toLowerCase()))
        );
        if (best) {
          window.location.href = '/' + best.slug;
        }
      }
    });
  }
</script>
