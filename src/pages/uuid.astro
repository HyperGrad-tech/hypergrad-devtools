---
import ToolLayout from '../layouts/ToolLayout.astro';
import UuidGenerator from '../components/tools/UuidGenerator.tsx';
---
<ToolLayout slug="uuid">
  <UuidGenerator client:load />
  <div slot="seo-content">
    <h2>UUID 生成器</h2>
    <p>批量生成 UUID（统一唯一标识符），支持 v4 随机版本和 v7 时间排序版本，可选大写、去横线输出，一次最多生成 1000 个并一键复制。</p>
    <h3>UUID 版本对比</h3>
    <ul>
      <li><strong>UUID v4</strong>：基于随机数生成，全局唯一性靠随机空间（122 位）保证，最常用。</li>
      <li><strong>UUID v7</strong>：RFC 9562 新标准，前 48 位为毫秒时间戳，按时间排序，适合数据库索引和日志检索。</li>
      <li><strong>GUID</strong>：微软对 UUID 的称呼，与 UUID v4 等价，本工具可直接生成 GUID。</li>
    </ul>
  </div>
</ToolLayout>
