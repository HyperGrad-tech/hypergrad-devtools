---
import ToolLayout from '../layouts/ToolLayout.astro';
import ImageCompress from '../components/tools/ImageCompress.tsx';
---
<ToolLayout slug="image-compress">
  <ImageCompress client:load />
  <div slot="seo-content">
    <h2>在线图片压缩工具</h2>
    <p>压缩 PNG、JPEG、WebP 图片，可调质量、缩放尺寸，浏览器本地处理，原图和新图都不会上传到任何服务器。压缩前后对比展示，并实时显示压缩率与节省的体积。</p>
    <h3>三种格式对比</h3>
    <ul>
      <li><strong>JPEG</strong>：有损压缩，体积小，不支持透明通道，适合作照片截图。</li>
      <li><strong>WebP</strong>：现代格式，同质量下比 JPEG 更小约 25%-35%，支持透明。</li>
      <li><strong>PNG</strong>：无损压缩，支持透明，体积较大，适合作图标、线稿。</li>
    </ul>
  </div>
</ToolLayout>
