---
import ToolLayout from '../layouts/ToolLayout.astro';
import HashGenerator from '../components/tools/HashGenerator.tsx';
---
<ToolLayout slug="hash">
  <HashGenerator client:load />
  <div slot="seo-content">
    <h2>哈希生成器</h2>
    <p>同时生成 MD5、SHA-1、SHA-256、SHA-512 哈希，支持 HMAC 带密钥哈希。SHA-256 是当前推荐的安全哈希算法。</p>
    <h3>算法对比</h3>
    <ul>
      <li><strong>MD5</strong>（128 位）：已不安全，存在碰撞，仅用于非安全场景的校验和。</li>
      <li><strong>SHA-1</strong>（160 位）：已被攻破，不推荐用于新场景。</li>
      <li><strong>SHA-256</strong>（256 位）：当前主流，用于区块链、TLS 证书、密码加盐哈希。</li>
      <li><strong>SHA-512</strong>（512 位）：更长，安全性更高，但速度稍慢。</li>
    </ul>
  </div>
</ToolLayout>
