---
import ToolLayout from '../layouts/ToolLayout.astro';
import SqlFormatter from '../components/tools/SqlFormatter.tsx';
---
<ToolLayout slug="sql-formatter">
  <SqlFormatter client:load />
  <div slot="seo-content">
    <h2>SQL 格式化工具</h2>
    <p>在线美化、压缩 SQL 语句，支持 14 种方言（MySQL、PostgreSQL、SQL Server、Oracle、SQLite、BigQuery、Snowflake 等），可自定义缩进、关键字大小写、语句间距。基于 sql-formatter 引擎，处理即时。</p>
    <h3>支持的方言</h3>
    <ul>
      <li><strong>关系型数据库</strong>：MySQL、MariaDB、PostgreSQL、SQLite、Oracle PL/SQL、SQL Server（T-SQL）、DB2。</li>
      <li><strong>数仓 / 大数据</strong>：BigQuery、Redshift、Snowflake、Spark、Hive、ClickHouse、Trino/Presto。</li>
      <li><strong>通用</strong>：Standard SQL。</li>
    </ul>
  </div>
</ToolLayout>
